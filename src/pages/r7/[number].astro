---
import Layout from '../../layouts/Layout.astro';
import { getQuestions, getQuestionWithExplanation, YEAR_INFO } from '../../utils/questions';

export function getStaticPaths() {
  const questions = getQuestions('r7');
  return questions.map(q => ({
    params: { number: String(q.number) },
  }));
}

const { number } = Astro.params;
const questionNum = parseInt(number);
const yearKey = 'r7';
const info = YEAR_INFO[yearKey];
const data = getQuestionWithExplanation(yearKey, questionNum);

if (!data) {
  return Astro.redirect('/r7/');
}

const totalQuestions = getQuestions(yearKey).length;
const hasPrev = questionNum > 1;
const hasNext = questionNum < totalQuestions;

const referenceLines = data.explanationSections?.reference
  ? data.explanationSections.reference.split('\n').filter(l => l.trim())
  : [];

function renderMarkdown(text: string): string {
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/\n/g, '<br>');
}
---

<Layout
  title={`${info.label} 第${questionNum}問 | 技術士一次試験 過去問解説`}
  description={data.question.slice(0, 100)}
  activeYear={yearKey}
>
  <nav class="breadcrumb" aria-label="パンくずリスト">
    <a href="/">トップ</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/r7/">{info.label}</a>
    <span class="breadcrumb-sep">›</span>
    <span>第{questionNum}問</span>
  </nav>

  <h1>第{questionNum}問</h1>

  <div class="question-card">
    <div class="question-card-label">問題文</div>
    <p class="question-text">{data.question}</p>
  </div>

  <div class="choices-section-label">選択肢</div>
  <div class="choices-container" data-answer={data.answer}>
    {data.choices.map((choice, idx) => (
      <div class="choice-item" data-number={idx + 1}>
        {choice}
      </div>
    ))}
  </div>

  <div class="reveal-area">
    <button class="reveal-btn" id="reveal-btn" data-answer={data.answer} aria-expanded="false">
      答えを見る
    </button>
  </div>

  {data.explanationSections && (
    <div class="answer-section" id="answer-section" aria-hidden="true">
      <div class="answer-header">
        <span class="answer-label">正答</span>
        <span class="answer-value">{data.explanationSections.answer}</span>
      </div>

      <div class="explanation-block">
        <h2>解説</h2>
        <p class="explanation-text" set:html={renderMarkdown(data.explanationSections.explanation)} />
      </div>

      {referenceLines.length > 0 && (
        <div class="reference-block">
          <h2>参考</h2>
          <div class="reference-content">
            {referenceLines.map(line => (
              <div>
                {line.match(/^https?:\/\//)
                  ? <a href={line} target="_blank" rel="noopener noreferrer" class="ref-url">{line}</a>
                  : <span class="ref-label">{line}</span>
                }
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  )}

  <nav class="question-nav" aria-label="問題ナビゲーション">
    <div class="nav-prev">
      {hasPrev && (
        <a href={`/r7/${questionNum - 1}/`} class="nav-btn nav-btn--prev">
          <span class="nav-arrow">‹</span>
          <span>前の問題<br /><small>第{questionNum - 1}問</small></span>
        </a>
      )}
    </div>
    <a href="/r7/" class="nav-list-link">一覧へ</a>
    <div class="nav-next">
      {hasNext && (
        <a href={`/r7/${questionNum + 1}/`} class="nav-btn nav-btn--next">
          <span>次の問題<br /><small>第{questionNum + 1}問</small></span>
          <span class="nav-arrow">›</span>
        </a>
      )}
    </div>
  </nav>
</Layout>

<style>
  .question-card {
    background: #f0f7f2;
    border: 1px solid var(--color-primary-light);
    border-top: 3px solid var(--color-primary);
    border-radius: 8px;
    padding: 1rem 1.5rem 1.25rem;
    margin-bottom: 0.5rem;
  }

  .question-card-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.06em;
    margin-bottom: 0.6rem;
  }

  .question-text {
    font-size: 0.97rem;
    line-height: 1.85;
  }

  .choices-section-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
    margin: 1rem 0 0.5rem 0.25rem;
  }

  .choices-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .choice-item {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.85rem 1.1rem;
    font-size: 0.92rem;
    line-height: 1.7;
    transition: background 0.2s, border-color 0.2s;
  }

  .choice-item.correct {
    background: var(--color-correct-bg);
    border-color: var(--color-correct-border);
    font-weight: 500;
  }

  .choice-item.wrong {
    color: #999;
  }

  .reveal-area {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .reveal-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.75rem 2.5rem;
    font-size: 1rem;
    font-family: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
    letter-spacing: 0.03em;
  }

  .reveal-btn:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .reveal-btn:active {
    transform: translateY(0);
  }

  /* ─── Answer section (hidden initially) ─── */
  .answer-section {
    display: none;
    background: white;
    border: 2px solid var(--color-correct-border);
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    animation: slideDown 0.25s ease;
  }

  .answer-section.visible {
    display: block;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .answer-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .answer-label {
    background: var(--color-primary);
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .answer-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .explanation-block,
  .reference-block {
    margin-top: 1.25rem;
  }

  .explanation-text {
    font-size: 0.93rem;
    line-height: 1.85;
  }

  .reference-content {
    font-size: 0.85rem;
    line-height: 1.9;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .ref-label {
    color: var(--color-text-muted);
  }

  .ref-url {
    color: var(--color-primary);
    word-break: break-all;
  }

  .ref-url:hover {
    text-decoration: underline;
  }

  /* ─── Question nav ─── */
  .question-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .nav-prev,
  .nav-next {
    flex: 1;
  }

  .nav-next {
    text-align: right;
  }

  .nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.65rem 1rem;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.88rem;
    line-height: 1.4;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .nav-btn:hover {
    text-decoration: none;
    color: var(--color-primary);
    border-color: var(--color-primary-light);
    box-shadow: 0 2px 6px rgba(45, 106, 79, 0.1);
  }

  .nav-btn small {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .nav-arrow {
    font-size: 1.3rem;
    color: var(--color-primary-light);
    line-height: 1;
  }

  .nav-list-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .nav-list-link:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>

<script>
  const btn = document.getElementById('reveal-btn') as HTMLButtonElement | null;
  const section = document.getElementById('answer-section');
  const choicesContainer = document.querySelector('.choices-container') as HTMLElement | null;

  let revealed = false;

  btn?.addEventListener('click', () => {
    revealed = !revealed;

    if (revealed) {
      section?.classList.add('visible');
      section?.setAttribute('aria-hidden', 'false');
      btn.textContent = '隠す';
      btn.setAttribute('aria-expanded', 'true');

      const answer = parseInt(choicesContainer?.dataset.answer ?? '0');
      document.querySelectorAll('.choice-item').forEach((el, idx) => {
        const isCorrect = idx + 1 === answer;
        el.classList.toggle('correct', isCorrect);
        el.classList.toggle('wrong', !isCorrect);
      });
    } else {
      section?.classList.remove('visible');
      section?.setAttribute('aria-hidden', 'true');
      btn.textContent = '答えを見る';
      btn.setAttribute('aria-expanded', 'false');

      document.querySelectorAll('.choice-item').forEach(el => {
        el.classList.remove('correct', 'wrong');
      });
    }
  });
</script>
